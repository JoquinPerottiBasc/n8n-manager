          "jsCode": "const celular = $json.data?.celular || '';\nlet digits = celular.replace(/[^\\d]/g, '');\n\nif (digits.startsWith('549') && digits.length >= 12) {\n  // Formato correcto: 549XXXXXXXXXX\n} else if (digits.startsWith('54') && digits.length >= 12) {\n  // Tiene código país pero falta el 9\n  digits = '549' + digits.slice(2);\n} else if (digits.startsWith('9') && digits.length === 11) {\n  // Tiene 9 pero falta código país\n  digits = '54' + digits;\n} else if (digits.startsWith('0') && digits.length >= 10) {\n  // Formato local con 0 al inicio\n  digits = '549' + digits.slice(1);\n} else if (digits.length === 10) {\n  // Solo código de área + número\n  digits = '549' + digits;\n}\n\nreturn [{ json: { ...$json, telefono_normalizado: digits } }];",
          "notice": ""
