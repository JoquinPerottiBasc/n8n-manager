          "jsCode": "const now = new Date();\nconst utcYear = now.getUTCFullYear();\nconst utcMonth = now.getUTCMonth();\nconst utcDate = now.getUTCDate();\n\n// Mañana a las 00:00 en Buenos Aires (UTC-3 = 03:00 UTC)\nconst tomorrowInBA = new Date(Date.UTC(utcYear, utcMonth, utcDate + 1, 3, 0, 0));\n\nconst yyyy = tomorrowInBA.getUTCFullYear();\nconst mm = String(tomorrowInBA.getUTCMonth() + 1).padStart(2, '0');\nconst dd = String(tomorrowInBA.getUTCDate()).padStart(2, '0');\nconst isoBA = `${yyyy}-${mm}-${dd}T00:00:00-03:00`;\n\nreturn [{ json: { tomorrow: isoBA } }];",
